{
  "expo": {
    "name": "expo-ocr-kit-example",
    "slug": "expo-ocr-kit-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "../app.plugin.js",
        {
          "cameraPermission": "Allow this app to capture receipts for OCR scanning."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow this app to capture receipts for OCR scanning.",
          "photosPermission": "Allow this app to choose receipt images for OCR scanning.",
          "microphonePermission": false
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "expo.modules.ocrkit.example"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "expo.modules.ocrkit.example"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
